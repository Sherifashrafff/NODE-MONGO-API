{
  "name": "node-mongo-api",
  "version": "1.0.0",
  "description": "Node.js REST API with MongoDB and Jenkins CI pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src/ test/ --max-warnings=0",
    "lint:fix": "eslint src/ test/ --fix",
    "pretest": "mkdir -p reports",
    "test": "jest --config config/jest.config.js --forceExit",
    "test:unit": "JEST_JUNIT_OUTPUT_NAME=unit-junit.xml jest --config config/jest.config.js --testPathPattern=test/unit --forceExit",
    "test:integration": "JEST_JUNIT_OUTPUT_NAME=integration-junit.xml jest --config config/jest.config.js --testPathPattern=test/integration --forceExit",
    "test:coverage": "jest --config config/jest.config.js --coverage --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
